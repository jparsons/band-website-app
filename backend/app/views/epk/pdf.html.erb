<% def blob_url(attachment, host)
  return nil unless attachment.attached?
  Rails.application.routes.url_helpers.rails_blob_url(attachment, host: host)
end %>

<div class="page">
  <!-- Header -->
  <div class="header">
    <% if @band.logo.attached? %>
      <img src="<%= blob_url(@band.logo, @host) %>" alt="<%= @band.name %>" class="logo">
    <% end %>
    <h1 class="band-name"><%= @band.name %></h1>
    <% if @band.epk_headline.present? %>
      <p class="headline"><%= @band.epk_headline %></p>
    <% end %>
    <% if @band.epk_one_sheet.present? %>
      <p class="one-sheet"><%= @band.epk_one_sheet %></p>
    <% end %>
  </div>

  <!-- Bio -->
  <% bio_content = @band.epk_short_bio.presence || @band.bio %>
  <% if bio_content.present? %>
    <div class="section">
      <h2 class="section-title">Biography</h2>
      <p class="bio"><%= bio_content %></p>
    </div>
  <% end %>

  <!-- Band Members -->
  <% if @band_members.any? %>
    <div class="section">
      <h2 class="section-title">Band Members</h2>
      <div class="members-grid">
        <% @band_members.each do |member| %>
          <div class="member">
            <% if member.photo.attached? %>
              <img src="<%= blob_url(member.photo, @host) %>" alt="<%= member.name %>" class="member-photo">
            <% end %>
            <p class="member-name"><%= member.name %></p>
            <% if member.role.present? %>
              <p class="member-role"><%= member.role %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Press Quotes -->
  <% if @press_quotes.any? %>
    <div class="section">
      <h2 class="section-title">Press</h2>
      <% @press_quotes.first(4).each do |quote| %>
        <div class="quote">
          <p class="quote-text">"<%= quote.quote %>"</p>
          <p class="quote-source">
            &mdash; <%= quote.author.present? ? "#{quote.author}, " : "" %><%= quote.source %>
          </p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<div class="page">
  <!-- Releases/Discography -->
  <% if @releases.any? %>
    <div class="section">
      <h2 class="section-title">Discography</h2>
      <div class="releases-grid">
        <% @releases.each do |release| %>
          <div class="release">
            <% if release.cover_art.attached? %>
              <img src="<%= blob_url(release.cover_art, @host) %>" alt="<%= release.title %>" class="release-cover">
            <% end %>
            <p class="release-title"><%= release.title %></p>
            <p class="release-info">
              <%= release.release_type.capitalize %>
              <% if release.release_date.present? %>
                &bull; <%= release.release_date.year %>
              <% end %>
            </p>
            <% if release.label.present? %>
              <p class="release-info"><%= release.label %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Upcoming Shows -->
  <% if @events.any? %>
    <div class="section">
      <h2 class="section-title">Upcoming Shows</h2>
      <ul class="events-list">
        <% @events.first(6).each do |event| %>
          <li class="event-item">
            <span class="event-date"><%= event.date.strftime('%b %d') %></span>
            <div class="event-info">
              <p class="event-title"><%= event.title %></p>
              <p class="event-venue"><%= event.venue %><%= event.city.present? ? ", #{event.city}" : "" %></p>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Contacts -->
  <% if @epk_contacts.any? %>
    <div class="section">
      <h2 class="section-title">Contact</h2>
      <div class="contacts-grid">
        <% @epk_contacts.each do |contact| %>
          <div class="contact-card">
            <p class="contact-type"><%= contact.contact_type %></p>
            <p class="contact-name"><%= contact.name %></p>
            <% if contact.company.present? %>
              <p class="contact-company"><%= contact.company %></p>
            <% end %>
            <div class="contact-details">
              <% if contact.email.present? %>
                <p><%= contact.email %></p>
              <% end %>
              <% if contact.phone.present? %>
                <p><%= contact.phone %></p>
              <% end %>
              <% if contact.territory.present? %>
                <p>Territory: <%= contact.territory %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Technical Rider Summary -->
  <% if @technical_rider_sections.any? %>
    <div class="section">
      <h2 class="section-title">Technical Rider</h2>
      <% @technical_rider_sections.each do |section| %>
        <div class="rider-section">
          <p class="rider-title"><%= section.title %></p>
          <% if section.content.present? %>
            <p class="rider-content"><%= section.content %></p>
          <% end %>
          <% if section.attachment.attached? %>
            <p class="rider-content"><em>Attachment: <%= section.attachment.filename %></em></p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Social Links -->
  <% if @band.social_links.present? && @band.social_links.values.any?(&:present?) %>
    <div class="social-links">
      <% if @band.social_links['spotify'].present? %>
        <span class="social-link">Spotify: <%= @band.social_links['spotify'] %></span>
      <% end %>
      <% if @band.social_links['instagram'].present? %>
        <span class="social-link">Instagram: <%= @band.social_links['instagram'] %></span>
      <% end %>
      <% if @band.social_links['facebook'].present? %>
        <span class="social-link">Facebook: <%= @band.social_links['facebook'] %></span>
      <% end %>
      <% if @band.social_links['twitter'].present? %>
        <span class="social-link">Twitter: <%= @band.social_links['twitter'] %></span>
      <% end %>
    </div>
  <% end %>

  <!-- Footer -->
  <div class="footer">
    <p><%= @band.name %> Electronic Press Kit &bull; Generated <%= Date.today.strftime('%B %Y') %></p>
  </div>
</div>
